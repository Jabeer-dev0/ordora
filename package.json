{
  "name": "ordora",
  "private": true,
  "workspaces": [
    "shared",
    "app",
    "admin"
  ],
  "scripts": {
    "dev:app": "cd app && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "dev": "concurrently \"npm run dev:app\" \"npm run dev:admin\"",
    "build": "cd app && npm run build && cd ../admin && npm run build",
    "vercel-build:app": "npx prisma generate && cd app && npm run build",
    "vercel-build:admin": "npx prisma generate && cd admin && npm run build",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.1"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "sonner": "^2.0.7"
  }
}
